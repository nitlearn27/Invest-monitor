# Local env (Drive credentials)
.env
.env.*
!.env.example

# Personal financial data — never commit (contains PAN, holdings, statements).
# Ignore the contents (not the dir itself) so the one build artifact below can be
# re-included — git can't un-ignore a file under a fully-ignored directory.
resources/*
# …except the MF name→AMFI scheme-code map, which the app imports at build time
# (navs.js) and bakes into the bundle. Scheme codes are public AMFI data.
!resources/mf-schemes.json
# …and the name→NSE-symbol maps, imported by classify.js at build time and baked
# into the bundle. NSE tickers are public data.
!resources/name-symbols.json

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
